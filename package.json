{
  "name": "@thaild12042003/atlas-forge",
  "version": "0.2.1",
  "description": "Local-first project memory operating layer for coding agents",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "atlas-forge": "dist/cli/bin.js",
    "atlas-forge-mcp": "dist/mcp/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/cli/bin.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "memory",
    "agent",
    "knowledge-base",
    "local-first",
    "ai-agent",
    "context",
    "cli"
  ],
  "author": "thaild12042003",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thaildhe172591/Atlas-Force.git"
  },
  "bugs": {
    "url": "https://github.com/thaildhe172591/Atlas-Force.git/issues"
  },
  "homepage": "https://github.com/thaildhe172591/Atlas-Force.git#readme",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^25.5.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^4.1.1"
  }
}
