{
  "name": "atlas-forge",
  "version": "0.1.0",
  "description": "Local-first project memory operating layer for coding agents",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "atlas-forge": "./dist/cli/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/cli/bin.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "memory",
    "agent",
    "knowledge",
    "local-first",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}